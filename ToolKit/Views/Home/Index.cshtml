
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Developer Toolkit</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f4f6f9;
            transition: 0.3s;
        }

        .hero {
            background: linear-gradient(135deg,#0d6efd,#6610f2);
            color: white;
            padding: 80px 0;
            text-align: center;
        }

        .tool-card {
            transition: 0.3s;
            cursor: pointer;
        }

            .tool-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            }

        .dark-mode {
            background: #121212;
            color: white;
        }

            .dark-mode .card {
                background: #1e1e1e;
                color: white;
            }

            .dark-mode footer {
                background: #000;
            }

        footer {
            margin-top: 50px;
        }

    </style>

</head>

<body>

    <!-- Navbar -->

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">

        <div class="container">

            <a class="navbar-brand" href="#">🛠 Developer Toolkit</a>

            <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">

                <input id="search"
                       class="form-control ms-auto me-2"
                       type="search"
                       placeholder="Search tools..."
                       onkeyup="searchTools()">

                <button class="btn btn-outline-light" onclick="toggleDarkMode()">🌙</button>

            </div>

        </div>

    </nav>

    <!-- Hero -->

    <section class="hero">

        <div class="container">

            <h1 class="display-5 fw-bold">All Developer Tools in One Place</h1>

            <p class="lead">
                Free utilities for developers & learners
            </p>

        </div>

    </section>


    <!-- Tools -->

    <div class="container py-5">

        <div class="row g-4" id="toolsContainer">

            <!-- Age Calculator -->


            <div class="col-md-4 tool">

                <a asp-controller="Home" asp-action="Age" class="text-decoration-none">

                    <div class="card tool-card text-center p-4">

                        <h2>🎂</h2>

                        <h5>Age Calculator</h5>

                        <p>Calculate your exact age instantly</p>

                    </div>

                </a>

            </div>
           
           

            <!-- Unit Converter -->

            <div class="col-md-4 tool">
                 <a asp-controller="Home" asp-action="Unit" class="text-decoration-none">

                <div class="card tool-card text-center p-4">

                    <h2>📏</h2>

                    <h5>Unit Converter</h5>

                    <p>Convert units quickly</p>

                </div>
                </a>
            </div>

            <!-- Password Generator -->

            <div class="col-md-4 tool">

                 <a asp-controller="Home" asp-action="Password" class="text-decoration-none">

                <div class="card tool-card text-center p-4">

                    <h2>🔑</h2>

                    <h5>Password Generator</h5>

                    <p>Create strong secure passwords</p>

                </div>
                </a> 
            </div>

            <!-- Random Quote -->

            <div class="col-md-4 tool">

                <a asp-controller="Home" asp-action="RandomQuote" class="text-decoration-none">
                <div class="card tool-card text-center p-4">

                    <h2>💬</h2>

                    <h5>Random Quote</h5>

                    <p>Generate inspirational quotes</p>

                </div>
                </a> 
            </div>

            <!-- Random Name Picker -->

            <div class="col-md-4 tool">

                <a asp-controller="Home" asp-action="RandomName" class="text-decoration-none">
                <div class="card tool-card text-center p-4">

                    <h2>🎲</h2>

                    <h5>Random Name Picker</h5>

                    <p>Pick a random name easily</p>

                </div>
                </a> 
            </div>

            <!-- Number Guessing Game -->

            <div class="col-md-4 tool">
                 <a asp-controller="Home" asp-action="NumberGuessing" class="text-decoration-none">

                <div class="card tool-card text-center p-4">

                    <h2>🎮</h2>

                    <h5>Number Guessing Game</h5>

                    <p>Fun guessing game</p>

                </div>
                </a>
            </div>

            <!-- Todo List -->

            <div class="col-md-4 tool">

                <a asp-controller="Home" asp-action="ToDoList" class="text-decoration-none">
                <div class="card tool-card text-center p-4">

                    <h2>📋</h2>

                    <h5>Todo List</h5>

                    <p>Manage your daily tasks</p>

                </div>
                </a>
            </div>

            <!-- Weather Checker -->

            <div class="col-md-4 tool">
                <a asp-controller="Home" asp-action="WeatherChecker" class="text-decoration-none">

                <div class="card tool-card text-center p-4">

                    <h2>🌦</h2>

                    <h5>Weather Checker</h5>

                    <p>Check weather instantly</p>

                </div>
                </a>


            </div>

        </div>

    </div>


    <!-- Footer -->

    <footer class="bg-dark text-white text-center p-3">

        <p>© 2026 Developer Toolkit</p>

    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function searchTools() {

            let input = document.getElementById("search").value.toLowerCase();

            let tools = document.querySelectorAll(".tool");

            tools.forEach(tool => {

                let text = tool.innerText.toLowerCase();

                tool.style.display = text.includes(input) ? "block" : "none";

            });

        }

        function toggleDarkMode() {

            document.body.classList.toggle("dark-mode");

        }

    </script>

</body>

</html>
```
