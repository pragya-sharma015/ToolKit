@{
    ViewData["Title"] = "Weather Checker";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg">

                <div class="card-header bg-info text-white text-center">
                    <h3>🌦 Weather Checker</h3>
                </div>

                <div class="card-body">

                    <div class="input-group mb-3">
                        <input type="text" id="city" class="form-control" placeholder="Enter city name">
                        <button class="btn btn-primary" onclick="getWeather()">Check</button>
                    </div>

                    <div id="weatherResult" class="text-center"></div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

    async function getWeather() {

        let city = document.getElementById("city").value;

        let apiKey = "c09816d6aaeb8c68999400967327c786";

        let url = `https://api.openweathermap.org/data/2.5/weather?q=${city}&appid=${apiKey}&units=metric`;

        try {

            let response = await fetch(url);

            let data = await response.json();

            if (data.cod == "404") {

                document.getElementById("weatherResult").innerHTML =
                    "<p class='text-danger'>City not found</p>";

                return;

            }

            document.getElementById("weatherResult").innerHTML = `
    <h4>${data.name}</h4>
    <p>🌡 Temperature: ${data.main.temp} °C</p>
    <p>☁ Weather: ${data.weather[0].description}</p>
    <p>💧 Humidity: ${data.main.humidity}%</p>
    `;

        }

        catch {

            document.getElementById("weatherResult").innerHTML =
                "<p class='text-danger'>Error fetching weather</p>";

        }

    }

</script>