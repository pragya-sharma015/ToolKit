@{
    ViewData["Title"] = "Unit Converter";
}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg">

                <div class="card-header bg-primary text-white text-center">
                    <h3>📏 Unit Converter</h3>
                </div>

                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label">Enter Value</label>
                        <input type="number" id="inputValue" class="form-control">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">From Unit</label>
                        <select id="fromUnit" class="form-control">
                            <option value="m">Meters</option>
                            <option value="km">Kilometers</option>
                            <option value="cm">Centimeters</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">To Unit</label>
                        <select id="toUnit" class="form-control">
                            <option value="m">Meters</option>
                            <option value="km">Kilometers</option>
                            <option value="cm">Centimeters</option>
                        </select>
                    </div>

                    <div class="d-grid">
                        <button class="btn btn-success" onclick="convertUnit()">Convert</button>
                    </div>

                    <h4 class="text-center mt-4" id="result"></h4>

                </div>
            </div>
        </div>
    </div>
</div>

<script>

    function convertUnit() {

        let value = parseFloat(document.getElementById("inputValue").value);
        let from = document.getElementById("fromUnit").value;
        let to = document.getElementById("toUnit").value;

        let result = value;

        if (from === "m" && to === "km") result = value / 1000;
        if (from === "km" && to === "m") result = value * 1000;
        if (from === "m" && to === "cm") result = value * 100;
        if (from === "cm" && to === "m") result = value / 100;

        document.getElementById("result").innerText = "Result: " + result;

    }

</script>